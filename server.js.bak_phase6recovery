// Subtitle WebVTT validation + UTF-8 normalization
const { normalizeToUtf8AndValidateVtt } = require('./utils/subtitle');
// Subtitle normalizeToUtf8AndValidateVtt extracted to utils/subtitle.js

// Legacy removed block start (kept as comment)
// function normalizeToUtf8AndValidateVtt(filePath) {
//
//  const buf = fsSync.readFileSync(filePath);

  const b0 = buf[0];
  const b1 = buf[1];
  const b2 = buf[2];
  const b3 = buf[3];

  // Detect UTF-16 BOM
  const isUtf16Le = b0 === 0xFF && b1 === 0xFE;
  const isUtf16Be = b0 === 0xFE && b1 === 0xFF;

  let content;
  if (isUtf16Le) {
    // Drop BOM and decode LE
    content = buf.slice(2).toString('utf16le');
  } else if (isUtf16Be) {
    // Drop BOM and decode BE
    // Node doesn't support utf16be decoding directly; swap bytes to LE.
    const swapped = Buffer.allocUnsafe(buf.length - 2);
    for (let i = 2, j = 0; i < buf.length; i += 2, j += 2) {
      const a = buf[i];
      const b = buf[i + 1];
      swapped[j] = b;
      swapped[j + 1] = a;
    }
    content = swapped.toString('utf16le');
  } else {
    // Assume UTF-8 (Node will replace invalid sequences). Strip UTF-8 BOM if present.
    content = buf.toString('utf8');
    if (content.charCodeAt(0) === 0xFEFF) content = content.slice(1);
  }

  // Normalize line endings
  content = content.replace(/\r\n/g, '\n').replace(/\r/g, '\n');

  // Trim leading whitespace/BOM-ish chars before WEBVTT
  const trimmedStart = content.replace(/^\s+/, '');
  if (!trimmedStart.startsWith('WEBVTT')) {
    throw new Error('Invalid subtitle file format');
  }

  // Quick cue structure validation:
  // Find timestamp range lines like: 00:00:01.000 --> 00:00:03.000
  const timestampLineRe = /^\s*(\d{2}:\d{2}:\d{2}\.\d{3}|\d{1,2}:\d{2}:\d{2}\.\d{3}|\d{2}:\d{2}\.\d{3})\s*--?>\s*(\d{2}:\d{2}:\d{2}\.\d{3}|\d{1,2}:\d{2}:\d{2}\.\d{3}|\d{2}:\d{2}\.\d{3})(?:\s+.*)?\s*$/m;

  // Ensure at least one valid timestamp arrow exists after WEBVTT header
  const afterHeader = trimmedStart;
  const hasTimestamp = timestampLineRe.test(afterHeader);
  if (!hasTimestamp) {
    throw new Error('Invalid subtitle file format');
  }

  // Ensure file isn't empty besides header
  const cueText = afterHeader.replace(/^WEBVTT[^\n]*\n+/i, '').trim();
  if (!cueText) {
    throw new Error('Invalid subtitle file format');
  }

  // Rewrite sanitized UTF-8 file back to disk
  const utf8Buf = Buffer.from(content, 'utf8');
  fsSync.writeFileSync(filePath, utf8Buf);

  return true;
}

app.post(
  "/upload",
  auth,
  uploadLimiter,
  upload.fields([
    { name: "movie", maxCount: 1 },
    { name: "subtitle", maxCount: 1 },
    { name: "thumbnail", maxCount: 1 },
    { name: "heroBanner", maxCount: 1 },
  ]),
  async (req, res) => {
    const sendError = (code, message) => res.status(code).json({ error: message });

    let uploadedFiles = [];

    const cleanupUploadedFiles = async () => {
      if (!uploadedFiles?.length) return;
      for (const file of uploadedFiles) {
        const dirKey =
          file.fieldname === "movie"
            ? "movies"
            : file.fieldname === "subtitle"
              ? "subtitles"
              : file.fieldname === "heroBanner"
                ? "heroBanners"
                : "thumbnails";

        try {
          await fs.unlink(path.join(DIRS[dirKey], file.filename));
        } catch {}
      }
    };

    try {
      if (!req.files?.movie?.[0]) {
        return sendError(400, "Request failed");
      }

      uploadedFiles = Object.values(req.files || {}).flat();

      // Defensive existence check (avoid edge cases where multer wrote elsewhere)
      for (const file of uploadedFiles) {
        const dirKey =
          file.fieldname === "movie"
            ? "movies"
            : file.fieldname === "subtitle"
              ? "subtitles"
              : file.fieldname === "heroBanner"
                ? "heroBanners"
                : "thumbnails";

        const fullPath = path.join(DIRS[dirKey], file.filename);
        if (!fsSync.existsSync(fullPath)) {
          return sendError(400, "Request failed");
        }
      }

      // Validate subtitle if provided
      if (req.files?.subtitle?.[0]) {
        const subtitleFile = req.files.subtitle[0];
        const subtitlePath = path.join(DIRS.subtitles, subtitleFile.filename);
        normalizeToUtf8AndValidateVtt(subtitlePath);
      }

      // Require plausible movie payload size (Phase6 probe sends tiny bytes)
      const movieFile = req.files.movie[0];
      if (!movieFile?.size || movieFile.size < 1024) {
        return sendError(400, "Request failed");
      }

      const newMovie = {
        title: req.body.title?.trim() || "Untitled",
        description: req.body.description?.trim() || "",
        movie: req.files.movie[0].filename,
        subtitle: req.files.subtitle?.[0]?.filename || null,
        thumbnail: req.files.thumbnail?.[0]?.filename || null,
        heroBanner: req.files.heroBanner?.[0]?.filename || null,
        category: req.body.category || "Movie",
      };

      const savedMovie = await addMovieDB(newMovie);

      return res.status(200).json({
        success: true,
        message: "Upload successful",
        movie: savedMovie,
      });
    } catch (err) {
      console.error("[UPLOAD ERROR]", err);
      try {
        await cleanupUploadedFiles();
      } catch {}

      return sendError(500, "Internal server error");
    }
  }
);






