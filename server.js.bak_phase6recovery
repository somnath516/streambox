const storage = multer.diskStorage({
  destination: (req, file, cb) => {
    if (file.fieldname === "movie") cb(null, DIRS.movies);
    else if (file.fieldname === "subtitle") cb(null, DIRS.subtitles);
    else if (file.fieldname === "heroBanner") cb(null, DIRS.heroBanners);
    else cb(null, DIRS.thumbnails);
  },
  filename: (req, file, cb) => {
    const name = `${Date.now()}-${Math.random().toString(36).substr(2, 9)}-${file.originalname.replace(/[^a-z0-9.-]/gi, '')}`;
    cb(null, name);
  }
});

const upload = multer({
  storage,
  limits: {
    fileSize: 500 * 1024 * 1024, // 500MB max
    files: 4
  },
  fileFilter: (req, file, cb) => {
    const allowedMimes = new Set([
      'video/mp4',
      'video/mkv',
      'image/jpeg',
      'image/png',
      'text/vtt'
    ]);

    // Block obvious executable/script files by extension too (defense-in-depth)
    const banned = /\.(exe|bat|sh|php|jsp|dll|com|scr)$/i;
    if (banned.test(file.originalname)) return cb(new Error('Upload rejected'), false);

    if (!allowedMimes.has(file.mimetype)) {
      return cb(new Error('Upload rejected'), false);
    }

    cb(null, true);
  }
});


