// Phase 6/7 routing hardening (anti-HTML-leak):
// Any request that targets /movies/... must never fall through to the SPA HTML.
// Only allow exactly one numeric path segment after /movies/.
app.use((req, res, next) => {
  const original = req.originalUrl || req.url || "";

  // Match: /movies/<something> (including encoded slashes)
  if (!original.startsWith('/movies/')) return next();

  // Extract first segment after /movies/
  // Decode to catch %2F (encoded forward slashes) which would otherwise become extra segments.
  const decoded = decodeURIComponent(original);
  const after = decoded.slice('/movies/'.length);
  const segs = after.split('/').filter(Boolean);

  // Must be exactly one segment and it must be all digits.
  if (segs.length !== 1 || !/^\d+$/.test(segs[0])) {
    return res.status(400).json({ error: 'Request failed' });
  }

  return next();
});

