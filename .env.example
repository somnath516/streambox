NODE_ENV=production
PORT=3000
STREAMBOX_ADMIN=replace-with-a-long-random-admin-token
SD_BASE=/media
HERO_BANNER_BASE=/media/hero banner
MEDIA_PATH=/media
UPLOAD_FILE_SIZE=524288000
UPLOAD_MAX_FILES=4
UPLOAD_RATE_LIMIT=10
UPLOAD_WINDOW_MS=900000
API_RATE_LIMIT=100
API_RATE_WINDOW_MS=60000
JSON_BODY_LIMIT=50mb
ENABLE_CSP=1
LOG_DIR=/app/logs
LOG_MAX_BYTES=10485760
PHASE6_PROBE=0
